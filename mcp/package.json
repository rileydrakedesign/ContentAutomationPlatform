{
  "name": "@agentsforx/mcp",
  "version": "1.0.0",
  "description": "MCP server for Agents For X \u2014 generate, draft, schedule, and publish X posts and replies in your voice, plus analytics.",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "bin": {
    "agentsforx-mcp": "dist/stdio.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/stdio.js",
    "inspector": "npm run build && npx @modelcontextprotocol/inspector node dist/stdio.js",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.6.0",
    "vitest": "^4.1.8"
  },
  "homepage": "https://app.agentsforx.com",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rileydrakedesign/ContentAutomationPlatform.git",
    "directory": "mcp"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "x",
    "twitter",
    "agents",
    "content",
    "claude"
  ]
}
