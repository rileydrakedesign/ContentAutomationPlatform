{
  "manifest_version": 3,
  "name": "Agents For X: AI Replies and Reply Targeting for X",
  "short_name": "Agents For X",
  "version": "1.4.0",
  "description": "Reply faster on X with personalized AI drafts, see which posts are worth your reply, and save tweets you love.",
  "permissions": [
    "storage",
    "activeTab"
  ],
  "host_permissions": [
    "https://x.com/*",
    "https://twitter.com/*",
    "https://app.agentsforx.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self';"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://x.com/*", "https://twitter.com/*"],
      "js": ["assistant-engine.js", "assistant-ui.js", "content.js"],
      "css": ["content.css"]
    },
    {
      "matches": ["https://app.agentsforx.com/*", "http://localhost:3000/*"],
      "js": ["bridge.js"],
      "run_at": "document_start"
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Agents For X",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
