# ──────────────────────────────────────────────────────────────────────────────
# Environment variables for the Next.js app (src/).
# Required vars are validated at boot by src/lib/env.ts — production refuses to
# start without them; development logs a warning.
# ──────────────────────────────────────────────────────────────────────────────

# Supabase — Project Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://[PROJECT-REF].supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# App — public origin, no trailing slash (used for OAuth redirects, QStash callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# OpenAI (post/reply generation, voice analysis)
OPENAI_API_KEY=sk-your-openai-api-key

# Anthropic (alternative generation model; required in production)
CLAUDE_API_KEY=your-claude-api-key

# Grok / xAI (optional generation model)
GROK_API_KEY=your-grok-api-key

# X / Twitter OAuth 2.0 confidential client — developer.x.com app settings
X_CLIENT_ID=your-x-client-id
X_CLIENT_SECRET=your-x-client-secret
# OAuth 1.0a keys (legacy BYO-app flows)
X_API_KEY=your-x-api-key
X_API_SECRET=your-x-api-secret
# Defaults to ${NEXT_PUBLIC_APP_URL}/api/x/callback when unset
X_REDIRECT_URI=http://localhost:3000/api/x/callback

# Stripe — dashboard.stripe.com > Developers > API keys / Webhooks
STRIPE_SECRET_KEY=sk_test_your-stripe-secret-key
STRIPE_WEBHOOK_SECRET=whsec_your-webhook-secret
NEXT_PUBLIC_STRIPE_PRO_PRICE_ID=price_your-pro-price-id

# QStash (scheduled post delivery) — console.upstash.com/qstash
QSTASH_TOKEN=your-qstash-token
# Public base origin of this app (no path, no trailing slash). QStash callback
# paths are appended to it, e.g. https://app.example.com -> .../api/qstash/publish
QSTASH_PUBLISH_URL=http://localhost:3000
QSTASH_CURRENT_SIGNING_KEY=sig_your-current-signing-key
QSTASH_NEXT_SIGNING_KEY=sig_your-next-signing-key

# Upstash Redis (API + auth rate limiting) — console.upstash.com/redis
# Rate limiting fails OPEN in dev without these, but fails CLOSED in production.
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token

# Cron auth — Vercel sends "Authorization: Bearer ${CRON_SECRET}" to /api/cron/*
CRON_SECRET=your-cron-secret

# Sentry error tracking (optional — no-op when unset)
SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
NEXT_PUBLIC_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# Build-time only — uploads source maps so prod stack traces are readable.
# Set in Vercel (Production/Preview) and CI, NOT in client/runtime. Keep secret.
SENTRY_AUTH_TOKEN=sntrys_exampleOrgAuthToken

# Chrome extension ID allowed by CORS (production Web Store ID)
EXTENSION_ID=your-chrome-extension-id
